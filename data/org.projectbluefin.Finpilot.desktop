[Desktop Entry]
Name=System Update
Comment=Check for and install system updates
Exec=finpilot
Icon=org.projectbluefin.Finpilot
Terminal=false
Type=Application
Categories=System;PackageManager;
Keywords=update;upgrade;system;uupd;
StartupNotify=true
# DBusActivatable ensures single-instance via GApplication
DBusActivatable=true
